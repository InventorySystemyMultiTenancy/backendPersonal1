generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  PERSONAL
  ALUNO
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum AgendaEventType {
  TREINO
  DIETA
  CONSULTA
  CHECKIN
  OUTRO
}

enum AgendaRecurrence {
  NONE
  WEEKLY
  MONTHLY
}

enum AttendanceStatus {
  PENDENTE
  CONFIRMADO
  FALTOU
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)

  // For ALUNO users linked to a tenant/personal.
  personalId   String?   @db.Uuid

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  personalProfile PersonalProfile? @relation("PersonalOwner")
  tenant          PersonalProfile? @relation("TenantUsers", fields: [personalId], references: [id], onDelete: SetNull)
  alunoProfile    Aluno?

  @@index([role])
  @@index([personalId])
}

model PersonalProfile {
  id            String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @db.Uuid
  businessName   String
  subdomain      String?      @unique
  phone          String?
  status         TenantStatus @default(ACTIVE)
  defaultPlan    PlanType     @default(FREE)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation("PersonalOwner", fields: [userId], references: [id], onDelete: Cascade)
  users          User[]       @relation("TenantUsers")
  alunos         Aluno[]
  alunoPlans     AlunoPlan[]
  workoutPlans   WorkoutPlan[]
  payments       Payment[]
  subscriptions  TenantSubscription[]
  agendaEvents   AgendaEvent[]
  dietPlans      DietPlan[]
  dietPlanDays   DietPlanDay[]

  @@index([status])
  @@index([subdomain])
}

model Aluno {
  id             String      @id @default(uuid()) @db.Uuid
  personalId     String      @db.Uuid
  userId         String?     @unique @db.Uuid
  alunoPlanId    String?     @db.Uuid

  fullName       String
  email          String?
  phone          String?
  birthDate      DateTime?
  planDueDate    DateTime?
  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  personal       PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  alunoPlan      AlunoPlan?  @relation(fields: [alunoPlanId], references: [id], onDelete: SetNull)
  workoutPlans   WorkoutPlan[]
  payments       Payment[]
  agendaEvents   AgendaEvent[]
  dietPlans      DietPlan[]
  alunoSubscriptions AlunoSubscription[]

  @@index([personalId])
  @@index([alunoPlanId])
  @@index([isActive])
}

model AlunoSubscription {
  id             String      @id @default(uuid()) @db.Uuid
  alunoId        String      @db.Uuid
  alunoPlanId    String      @db.Uuid
  
  payer_email    String
  mp_preapproval_id String   @unique
  mp_plan_id     String
  external_reference String?
  status         String      @default("pending") // pending, authorized, paused, canceled
  provider_status String?
  next_payment_date DateTime?
  card_token_last4 String?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  aluno          Aluno       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  alunoPlan      AlunoPlan   @relation(fields: [alunoPlanId], references: [id], onDelete: Restrict)
  events         AlunoSubscriptionEvent[]

  @@index([alunoId])
  @@index([status])
  @@index([external_reference])
  @@index([mp_preapproval_id])
}

model AlunoSubscriptionEvent {
  id             String      @id @default(uuid()) @db.Uuid
  alunoSubscriptionId String  @db.Uuid
  
  provider_event_key String?  @unique
  type           String
  status         String?
  message        String?
  payload        Json?
  
  createdAt      DateTime    @default(now())

  subscription   AlunoSubscription @relation(fields: [alunoSubscriptionId], references: [id], onDelete: Cascade)

  @@index([alunoSubscriptionId])
}

model WorkoutPlan {
  id             String      @id @default(uuid()) @db.Uuid
  personalId     String      @db.Uuid
  alunoId        String      @db.Uuid

  title          String
  objective      String?
  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  personal       PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  aluno          Aluno       @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  items          WorkoutPlanItem[]
  agendaEvents   AgendaEvent[]

  @@index([personalId])
  @@index([alunoId])
}

model WorkoutPlanItem {
  id             String      @id @default(uuid()) @db.Uuid
  personalId     String      @db.Uuid
  workoutPlanId  String      @db.Uuid
  exerciseName   String
  sets           Int
  reps           String
  restSeconds    Int?
  notes          String?
  orderIndex     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  workoutPlan    WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([personalId])
  @@index([workoutPlanId])
  @@index([orderIndex])
}

model AlunoPlan {
  id             String      @id @default(uuid()) @db.Uuid
  personalId     String      @db.Uuid
  name           String
  description    String?
  monthlyPriceCents Int
  isActive       Boolean     @default(true)
  
  // Campos para sincronização com Mercado Pago
  mp_plan_id     String?     @unique
  mp_sync_status String      @default("pending") // pending, synced, error
  mp_sync_error  String?
  mp_synced_at   DateTime?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  personal       PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  alunos         Aluno[]
  alunoSubscriptions AlunoSubscription[]

  @@index([personalId])
  @@index([isActive])
  @@index([mp_plan_id])
}

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  personalId     String        @db.Uuid
  alunoId        String?       @db.Uuid

  amountCents    Int
  currency       String        @default("BRL")
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  externalRef    String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  personal       PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  aluno          Aluno?        @relation(fields: [alunoId], references: [id], onDelete: SetNull)

  @@index([personalId])
  @@index([alunoId])
  @@index([status])
}

model TenantSubscription {
  id             String      @id @default(uuid()) @db.Uuid
  personalId     String      @db.Uuid
  plan           PlanType
  subscriptionPlanId String? @db.Uuid
  startedAt      DateTime    @default(now())
  endsAt         DateTime?
  isActive       Boolean     @default(true)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  personal       PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  subscriptionPlan SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)

  @@index([personalId])
  @@index([plan])
  @@index([isActive])
  @@index([subscriptionPlanId])
}

model SubscriptionPlan {
  id           String          @id @default(uuid()) @db.Uuid
  code         String          @unique
  name         String
  description  String?
  plan         PlanType
  interval     BillingInterval @default(MONTHLY)
  priceCents   Int
  currency     String          @default("BRL")
  isActive     Boolean         @default(true)
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  subscriptions TenantSubscription[]

  @@index([isActive])
  @@index([plan])
  @@index([sortOrder])
}

model AgendaEvent {
  id            String         @id @default(uuid()) @db.Uuid
  personalId    String         @db.Uuid
  alunoId       String         @db.Uuid
  workoutPlanId String?        @db.Uuid
  type          AgendaEventType @default(OUTRO)
  recurrence    AgendaRecurrence @default(NONE)
  recurrenceUntil DateTime?
  recurrenceGroupId String?      @db.Uuid
  attendanceStatus AttendanceStatus @default(PENDENTE)
  title         String
  description   String?
  dietNotes     String?
  startsAt      DateTime
  endsAt        DateTime?
  isDone        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  personal      PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  aluno         Aluno           @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  workoutPlan   WorkoutPlan?    @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)

  @@index([personalId])
  @@index([alunoId])
  @@index([startsAt])
  @@index([type])
}

model DietPlan {
  id            String       @id @default(uuid()) @db.Uuid
  personalId    String       @db.Uuid
  alunoId       String       @db.Uuid
  title         String
  description   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  personal      PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  aluno         Aluno           @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  days          DietPlanDay[]

  @@index([personalId])
  @@index([alunoId])
}

model DietPlanDay {
  id            String       @id @default(uuid()) @db.Uuid
  personalId    String       @db.Uuid
  dietPlanId    String       @db.Uuid
  weekday       Weekday
  mealPlan      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  personal      PersonalProfile @relation(fields: [personalId], references: [id], onDelete: Restrict)
  dietPlan      DietPlan        @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  @@unique([dietPlanId, weekday])
  @@index([personalId])
  @@index([dietPlanId])
  @@index([weekday])
}
